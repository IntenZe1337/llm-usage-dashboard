# ── Lokal data (kräver inga nycklar, läses från monterade volymer) ──────────
# Sätts automatiskt via docker-compose volumes. Ändra bara om sökväg avviker.
CODEX_DB=/data/codex/state_5.sqlite
CLAUDE_META_DIR=/data/claude/usage-data/session-meta

# ── Valfritt: Claude.ai abonnemangsstatus ────────────────────────────────────
# Hämta sessionKey/sessionKeyLC från claude.ai i webbläsaren.
# Om Claude svarar 403: använd full Cookie-header från DevTools Network "Copy as cURL"
# och sätt CLAUDE_ORG_ID till org-id:t i Claude-requestens URL.
CLAUDE_SESSION_KEY=
CLAUDE_SESSION_KEY_LC=
CLAUDE_COOKIE=
CLAUDE_ORG_ID=

# ── Valfritt: Anthropic Admin API-nyckel (sk-ant-admin...) ──────────────────
# Kräver admin-roll i Console → Settings → Organization → Admin Keys
ANTHROPIC_ADMIN_KEY=

# ── Valfritt: OpenAI Admin API-nyckel ───────────────────────────────────────
# Hämta från platform.openai.com/settings/organization/admin-keys
OPENAI_ADMIN_KEY=

# Cache-tid i sekunder (standard 300 = 5 min)
CACHE_TTL_SECONDS=300

# Valfritt: skydda POST /refresh med Authorization: Bearer <token>.
# Om tomt behålls bakåtkompatibelt oskyddat refresh-anrop.
REFRESH_TOKEN=

# Valfritt: kommaseparerad CORS allowlist. Tomt innebär ingen CORS-middleware.
# Exempel: CORS_ALLOW_ORIGINS=http://100.106.95.127:3000
CORS_ALLOW_ORIGINS=
