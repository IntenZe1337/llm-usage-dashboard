# ── Lokal data (kräver inga nycklar, läses från monterade volymer) ──────────
# Sätts automatiskt via docker-compose volumes. Ändra bara om sökväg avviker.
CODEX_DB=/data/codex/state_5.sqlite
CLAUDE_META_DIR=/data/claude/usage-data/session-meta

# ── Valfritt: Claude.ai abonnemangsstatus ────────────────────────────────────
# Hämta sessionKey-cookien från claude.ai i webbläsaren:
# DevTools → Application → Cookies → claude.ai → sessionKey
CLAUDE_SESSION_KEY=

# ── Valfritt: Anthropic Admin API-nyckel (sk-ant-admin...) ──────────────────
# Kräver admin-roll i Console → Settings → Organization → Admin Keys
ANTHROPIC_ADMIN_KEY=

# ── Valfritt: OpenAI Admin API-nyckel ───────────────────────────────────────
# Hämta från platform.openai.com/settings/organization/admin-keys
OPENAI_ADMIN_KEY=

# Cache-tid i sekunder (standard 300 = 5 min)
CACHE_TTL_SECONDS=300
